ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
DEPLOYER_PRIVATE_KEY=replace_with_testnet_deployer_private_key_do_not_commit_real_value
PROJECT_OWNER_ADDRESS=0x_your_builder_wallet_address

# Phase 4A public-wallet swap frontend config lives in assets/arqis-config.js.
# Copy assets/arqis-config.example.js -> assets/arqis-config.js and set the public Circle Kit Key there.
# assets/arqis-config.js is gitignored because it is environment-specific.
# Do not put PRIVATE_KEY, DEPLOYER_PRIVATE_KEY, CIRCLE_API_KEY, or CIRCLE_ENTITY_SECRET in browser config.

# Phase 4A.0 Circle App Kit Swap spike — server-side/local CLI only.
# Never expose KIT_KEY or wallet secrets in browser/NEXT_PUBLIC env vars.
KIT_KEY=replace_with_public_or_spike_circle_kit_key
SWAP_ADAPTER=viem-private-key
PRIVATE_KEY=replace_with_test_wallet_private_key_do_not_commit_real_value
SWAP_SLIPPAGE_BPS=300
# Optional: permit | approve. Empty uses SDK default: permit with fallback to approve.
SWAP_ALLOWANCE_STRATEGY=
# Optional route filter: sanity-usdc-to-eurc | main-eurc-to-usdc | optional-cirbtc-to-usdc
SWAP_ROUTE=
# Required only with --execute; must match SWAP_ROUTE or a route label.
SWAP_EXECUTE_ROUTE=
# Required only with --execute; must be exactly yes.
SWAP_CONFIRM_ARC_TESTNET=

# Alternative SWAP_ADAPTER=circle-wallets — server-side/local CLI only.
CIRCLE_API_KEY=replace_with_circle_api_key_do_not_commit_real_value
CIRCLE_ENTITY_SECRET=replace_with_circle_entity_secret_do_not_commit_real_value
CIRCLE_WALLET_ADDRESS=0x_your_circle_wallet_address
